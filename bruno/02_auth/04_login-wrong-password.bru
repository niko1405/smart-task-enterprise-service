meta {
  name: Login - Falsches Passwort (401)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "demo@smarttask.dev",
    "password": "wrongpassword"
  }
}

tests {
  test("Status ist 401 Unauthorized", function() {
    expect(res.status).to.equal(401);
  });

  test("success ist false", function() {
    expect(res.body.success).to.equal(false);
  });
}
