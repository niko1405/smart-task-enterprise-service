meta {
  name: Tasks filtern nach Priorität (HIGH)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/tasks
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:query {
  priority: HIGH
}

tests {
  test("Status ist 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("Alle zurückgegebenen Tasks haben Priorität HIGH", function() {
    res.body.data.data.forEach(function(task) {
      expect(task.priority).to.equal("HIGH");
    });
  });
}
