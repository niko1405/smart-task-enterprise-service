meta {
  name: Task per ID - Nicht gefunden (404)
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/tasks/00000000-0000-0000-0000-000000000000
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status ist 404 Not Found", function() {
    expect(res.status).to.equal(404);
  });

  test("success ist false", function() {
    expect(res.body.success).to.equal(false);
  });
}
