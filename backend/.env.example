PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL="postgresql://smarttask:smarttask_secret@localhost:5432/smarttask_db?schema=public"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Test Mode (true = wipe & seed DB on startup)
TEST_MODE=true

# Email (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@smarttask.local

# Application URL (used in email templates)
APP_URL=http://localhost:5173
